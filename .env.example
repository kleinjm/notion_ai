# Notion internal integration secret (starts with "ntn_" or "secret_")
NOTION_PAT=

# Source database: rows with Today=true get copied out
SOURCE_DB_ID=2ce27aa37b1e807b9d72f8f53e52c1b0

# Target database: copies land here, stamped with today's date
TARGET_DB_ID=b8227aa37b1e83c5ba018121c71349e8

# --- Property name overrides (leave blank to auto-detect) ---
# Name of the checkbox property on the SOURCE db
TODAY_PROP=Today
# Name of the date property on the TARGET db to stamp with today's date
TARGET_DATE_PROP=

# --- Testing ---
# When set, only this single source page id is processed (the "Crab Walks" test record)
TEST_PAGE_ID=2f827aa37b1e802db515fb458477df20
# When "true", read-only: prints what would happen without writing
DRY_RUN=false
